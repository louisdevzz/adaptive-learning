# Database
DATABASE_URL=postgresql://user:password@localhost:5432/adaptive_learning

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7D

# API Key
API_KEY=your-super-secret-api-key-change-this

# Server
PORT=8000
NODE_ENV=development

# CORS (comma-separated list of allowed origins)
# For production on Vercel, add your frontend URL, e.g.: https://your-app.vercel.app
# Example: CORS_ORIGIN=https://your-app.vercel.app,http://localhost:3000
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

FIREBASE_PROJECT_ID=adaptive-learningz
FIREBASE_SERVICE_ACCOUNT_KEY=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Shared AI switch (if set, this overrides request aiModel)
# Supported: openai | gemini | kimi-code
PROVIDER=openai
MODEL=

# Kimi (OpenAI-compatible endpoint)
KIMI_API_KEY=
KIMI_MODEL=kimi-coding
KIMI_BASE_URL=https://api.kimi.com/coding/v1
KIMI_USER_AGENT=KimiCLI/0.77
